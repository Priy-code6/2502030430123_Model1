<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>B.Tech CE 4th Sem Timetable</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f9;
            margin: 20px;
        }

        h1 {
            text-align: center;
            color: #1e3a8a;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        th, td {
            border: 1px solid #ccc;
            padding: 12px;
            text-align: center;
        }

        th {
            background-color: #2563eb;
            color: white;
        }

        tr:nth-child(even) {
            background-color: #f9fafb;
        }

        .break {
            background-color: #fde68a;
            font-weight: bold;
        }

        .lab {
            background-color: #bbf7d0;
        }

        .subject {
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h1>B.Tech Computer Engineering - 4th Semester Timetable</h1>

    <table>
        <tr>
            <th>Time</th>
            <th>Monday</th>
            <th>Tuesday</th>
            <th>Wednesday</th>
            <th>Thursday</th>
            <th>Friday</th>
            <th>Saturday</th>
        </tr>

        <tr>
            <td>10:00 - 11:00</td>
            <td class="subject">Data Structures</td>
            <td class="subject">DBMS</td>
            <td class="subject">Operating System</td>
            <td class="subject">Java</td>
            <td class="subject">DAA</td>
            <td class="subject">Mathematics</td>
        </tr>

        <tr>
            <td>11:00 - 12:00</td>
            <td class="subject">Java</td>
            <td class="subject">PYTHON</td>
            <td class="subject">DBMS</td>
            <td class="subject">Operating System</td>
            <td class="subject">Java</td>
            <td class="subject">Soft Skills</td>
        </tr>

        <tr>
            <td>12:00 - 12:20</td>
            <td colspan="6" class="break">Lunch Break</td>
        </tr>

        <tr>
            <td>12:20 - 1:20</td>
            <td class="lab">DBMS Lab</td>
            <td class="subject">Mathematics</td>
            <td class="subject">DAA</td>
            <td class="lab">Java Lab</td>
            <td class="subject">Operating System</td>
            <td class="subject">Library</td>
        </tr>

        <tr>
            <td>1:20 - 2:20</td>
            <td class="lab">DBMS Lab</td>
            <td class="subject">Java</td>
            <td class="subject">CGVM</td>
            <td class="lab">Java Lab</td>
            <td class="subject">DBMS</td>
            <td class="subject">Seminar</td>
        </tr>

        <tr>
            <td>2:20 -2:30</td>
            <td colspan="6" class="break">Short Break</td>
        </tr>

        <tr>
            <td>2:30 - 3:30</td>
            <td class="subject">Operating System</td>
            <td class="lab">OS Lab</td>
            <td class="subject">Java</td>
            <td class="subject">DBMS</td>
            <td class="lab">Project Work</td>
            <td class="subject">Sports</td>
        </tr>

        <tr>
            <td>3:30 - 4:30</td>
            <td class="subject">PYTHON</td>
            <td class="lab">OS Lab</td>
            <td class="subject">Soft Skills</td>
            <td class="subject">CGVM</td>
            <td class="lab">Project Work</td>
            <td class="subject">Activity</td>
        </tr>

    </table>

</body>
</html>
